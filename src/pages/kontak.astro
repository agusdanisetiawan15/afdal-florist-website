---
import BaseLayout from "../layouts/BaseLayout.astro";
import GoogleMap from "../components/GoogleMap.astro";
import { STORE_INFO, getWhatsAppUrl } from "../data/products";
---

<BaseLayout
  title="Kontak"
  description="Hubungi Afdal Florist - Toko bunga di Jl. Siliwangi, Rangkasbitung, Lebak, Banten. Order via WhatsApp 0889-0588-2925. Buka Senin-Sabtu 08.00-17.00 WIB."
  keywords="kontak afdal florist, alamat toko bunga rangkasbitung, whatsapp florist lebak, lokasi toko bunga banten"
>
  <!-- Page Header -->
  <section class="bg-gradient-to-br from-white via-gold-50 to-gold-100 py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-3xl md:text-5xl font-serif font-bold text-gray-900">
        Hubungi <span class="text-gold-600">Kami</span>
      </h1>
      <p class="mt-4 text-gray-600 max-w-2xl mx-auto">
        Kami siap melayani Anda. Hubungi kami untuk konsultasi dan pemesanan rangkaian bunga.
      </p>
    </div>
  </section>

  <!-- Contact Content -->
  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <!-- Contact Details -->
        <div>
          <h2 class="text-2xl font-serif font-bold text-gray-900 mb-8">Informasi Kontak</h2>

          <div class="space-y-6">
            <!-- Address -->
            <div class="flex items-start gap-4 p-5 bg-gray-50 rounded-xl">
              <div class="w-12 h-12 bg-gold-100 rounded-lg flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-gold-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-gray-900 mb-1">Alamat</h3>
                <p class="text-sm text-gray-600">{STORE_INFO.address}</p>
                <a
                  href={STORE_INFO.googleMapsLink}
                  target="_blank"
                  rel="noopener"
                  class="inline-flex items-center text-sm text-gold-600 hover:text-gold-700 mt-2 font-medium"
                >
                  Buka di Google Maps
                  <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                  </svg>
                </a>
              </div>
            </div>

            <!-- WhatsApp -->
            <div class="flex items-start gap-4 p-5 bg-gray-50 rounded-xl">
              <div class="w-12 h-12 bg-green-100 rounded-lg flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-green-600" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z" />
                  <path d="M12 0C5.373 0 0 5.373 0 12c0 2.625.846 5.059 2.284 7.034L.789 23.492a.5.5 0 00.611.611l4.458-1.495A11.96 11.96 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-2.379 0-4.574-.826-6.305-2.207l-.44-.351-3.237 1.085 1.085-3.237-.351-.44A9.96 9.96 0 012 12C2 6.486 6.486 2 12 2s10 4.486 10 10-4.486 10-10 10z" />
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-gray-900 mb-1">WhatsApp</h3>
                <p class="text-sm text-gray-600">Chat langsung untuk pemesanan</p>
                <a
                  href={getWhatsAppUrl()}
                  target="_blank"
                  rel="noopener"
                  class="inline-flex items-center text-sm text-green-600 hover:text-green-700 mt-2 font-medium"
                >
                  Kirim Pesan
                  <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                  </svg>
                </a>
              </div>
            </div>

            <!-- Operating Hours -->
            <div class="flex items-start gap-4 p-5 bg-gray-50 rounded-xl">
              <div class="w-12 h-12 bg-gold-100 rounded-lg flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-gold-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-gray-900 mb-1">Jam Operasional</h3>
                <p class="text-sm text-gray-600">Senin - Sabtu: 08.00 - 17.00 WIB</p>
                <p class="text-sm text-gray-600">Minggu: Tutup</p>
              </div>
            </div>
          </div>

          <!-- CTA Button -->
          <a
            href={getWhatsAppUrl()}
            target="_blank"
            rel="noopener"
            class="mt-8 inline-flex items-center justify-center w-full px-6 py-3.5 bg-[#25D366] text-white font-semibold rounded-lg hover:bg-[#20bd5a] transition-colors shadow-lg"
          >
            <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z" />
              <path d="M12 0C5.373 0 0 5.373 0 12c0 2.625.846 5.059 2.284 7.034L.789 23.492a.5.5 0 00.611.611l4.458-1.495A11.96 11.96 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-2.379 0-4.574-.826-6.305-2.207l-.44-.351-3.237 1.085 1.085-3.237-.351-.44A9.96 9.96 0 012 12C2 6.486 6.486 2 12 2s10 4.486 10 10-4.486 10-10 10z" />
            </svg>
            Langsung Pesan via WhatsApp
          </a>
        </div>

        <!-- Google Maps -->
        <div>
          <h2 class="text-2xl font-serif font-bold text-gray-900 mb-8">Lokasi Kami</h2>
          <GoogleMap embedUrl={STORE_INFO.googleMapsEmbed} />
          <p class="mt-4 text-sm text-gray-500 text-center">
            Jl. Siliwangi, Rangkasbitung Timur, Kab. Lebak, Banten
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
