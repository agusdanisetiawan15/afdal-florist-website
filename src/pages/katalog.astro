---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProductCard from "../components/ProductCard.astro";
import { products, categories } from "../data/products";
---

<BaseLayout
  title="Katalog Produk"
  description="Katalog lengkap Afdal Florist - Buket bunga, papan bunga duka cita & selamat, standing flower, bunga meja, dan rangkaian kustom. Pesan langsung via WhatsApp."
  keywords="katalog bunga rangkasbitung, harga buket bunga, papan bunga duka cita, papan bunga selamat, standing flower lebak, bunga meja rangkasbitung"
>
  <!-- Page Header -->
  <section class="bg-gradient-to-br from-white via-gold-50 to-gold-100 py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-3xl md:text-5xl font-serif font-bold text-gray-900">
        Katalog <span class="text-gold-600">Produk</span>
      </h1>
      <p class="mt-4 text-gray-600 max-w-2xl mx-auto">
        Jelajahi koleksi rangkaian bunga kami. Klik tombol WhatsApp untuk langsung memesan.
      </p>

      <!-- Category Quick Links -->
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        {categories.map((cat) => (
          <a
            href={`#${cat.id}`}
            class="px-5 py-2 bg-white border border-gold-200 text-gold-700 text-sm font-medium rounded-full hover:bg-gold-600 hover:text-white hover:border-gold-600 transition-colors shadow-sm"
          >
            {cat.label}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Product Sections -->
  {categories.map((cat) => {
    const categoryProducts = products.filter((p) => p.category === cat.id);
    return (
      <section id={cat.id} class="py-16 md:py-20 even:bg-gray-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="mb-10">
            <h2 class="text-2xl md:text-3xl font-serif font-bold text-gray-900">
              {cat.label}
            </h2>
            <p class="mt-2 text-gray-500">{cat.description}</p>
            <div class="mt-3 w-16 h-1 bg-gold-500 rounded-full"></div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
            {categoryProducts.map((product) => (
              <ProductCard product={product} />
            ))}
          </div>
        </div>
      </section>
    );
  })}
</BaseLayout>
