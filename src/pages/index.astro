---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroSection from "../components/HeroSection.astro";
import CategoryCard from "../components/CategoryCard.astro";
import { categories, getWhatsAppUrl } from "../data/products";
---

<BaseLayout
  title="Home"
  description="Afdal Florist - Toko bunga terpercaya di Rangkasbitung, Lebak, Banten. Buket bunga segar, papan bunga, standing flower, bunga meja & rangkaian kustom. Order mudah via WhatsApp."
  keywords="toko bunga rangkasbitung, florist rangkasbitung, buket bunga lebak, papan bunga banten, afdal florist, toko bunga 24 jam rangkasbitung"
>
  <!-- Hero -->
  <HeroSection />

  <!-- Keunggulan Kami -->
  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-serif font-bold text-gray-900">
          Kenapa Memilih <span class="text-gold-600">Afdal Florist</span>?
        </h2>
        <p class="mt-4 text-gray-500 max-w-2xl mx-auto">
          Kami berkomitmen memberikan pelayanan dan produk terbaik untuk Anda.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
        <!-- Feature 1 -->
        <div class="text-center p-6">
          <div class="w-14 h-14 bg-gold-50 rounded-xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-gold-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
            </svg>
          </div>
          <h3 class="font-semibold text-gray-900 mb-2">Bunga Segar</h3>
          <p class="text-sm text-gray-500">Bunga segar pilihan terbaik setiap hari untuk memastikan kualitas rangkaian.</p>
        </div>

        <!-- Feature 2 -->
        <div class="text-center p-6">
          <div class="w-14 h-14 bg-gold-50 rounded-xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-gold-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h3 class="font-semibold text-gray-900 mb-2">Pengiriman Cepat</h3>
          <p class="text-sm text-gray-500">Layanan pengiriman cepat ke seluruh area Rangkasbitung dan sekitarnya.</p>
        </div>

        <!-- Feature 3 -->
        <div class="text-center p-6">
          <div class="w-14 h-14 bg-gold-50 rounded-xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-gold-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a2 2 0 110-4h1a1 1 0 001-1V7a1 1 0 011-1h3a1 1 0 001-1V4z" />
            </svg>
          </div>
          <h3 class="font-semibold text-gray-900 mb-2">Desain Kustom</h3>
          <p class="text-sm text-gray-500">Bisa request desain sesuai keinginan Anda untuk acara spesial.</p>
        </div>

        <!-- Feature 4 -->
        <div class="text-center p-6">
          <div class="w-14 h-14 bg-gold-50 rounded-xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-gold-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="font-semibold text-gray-900 mb-2">Harga Terjangkau</h3>
          <p class="text-sm text-gray-500">Harga bersaing dengan kualitas premium untuk semua kalangan.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Kategori Produk -->
  <section class="py-16 md:py-24 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-serif font-bold text-gray-900">
          Kategori <span class="text-gold-600">Produk</span>
        </h2>
        <p class="mt-4 text-gray-500 max-w-2xl mx-auto">
          Jelajahi koleksi rangkaian bunga kami untuk berbagai keperluan.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {categories.map((cat) => (
          <CategoryCard
            title={cat.label}
            description={cat.description}
            image={cat.image}
            href={`/katalog#${cat.id}`}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Tentang Kami -->
  <section id="tentang-kami" class="py-16 md:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
        <!-- Image -->
        <div class="relative">
          <div class="rounded-2xl overflow-hidden shadow-xl">
            <img
              src="/images/custom-1.jpeg"
              alt="Rangkaian bunga kustom oleh Afdal Florist Rangkasbitung"
              class="w-full h-auto object-cover"
            />
          </div>
          <div class="absolute -bottom-4 -right-4 w-24 h-24 bg-gold-500 rounded-2xl -z-10"></div>
        </div>

        <!-- Text -->
        <div>
          <div class="inline-block px-4 py-1.5 bg-gold-50 text-gold-600 text-sm font-medium rounded-full mb-4">
            Tentang Kami
          </div>
          <h2 class="text-3xl md:text-4xl font-serif font-bold text-gray-900 mb-6">
            Toko Bunga Terpercaya di <span class="text-gold-600">Rangkasbitung</span>
          </h2>
          <p class="text-gray-600 leading-relaxed mb-4">
            Afdal Florist adalah toko bunga yang berlokasi di Jl. Siliwangi, Rangkasbitung Timur.
            Kami menyediakan berbagai jenis rangkaian bunga segar untuk berbagai keperluan, mulai dari
            buket bunga untuk hadiah, papan bunga untuk ucapan selamat dan duka cita, hingga
            rangkaian bunga kustom sesuai permintaan Anda.
          </p>
          <p class="text-gray-600 leading-relaxed mb-6">
            Dengan pengalaman dan dedikasi, kami berkomitmen memberikan rangkaian bunga berkualitas
            terbaik dengan harga terjangkau. Kepuasan pelanggan adalah prioritas utama kami.
          </p>
          <div class="flex flex-wrap gap-6">
            <div>
              <div class="text-2xl font-bold text-gold-600">100+</div>
              <div class="text-sm text-gray-500">Pelanggan Puas</div>
            </div>
            <div>
              <div class="text-2xl font-bold text-gold-600">3</div>
              <div class="text-sm text-gray-500">Kategori Produk</div>
            </div>
            <div>
              <div class="text-2xl font-bold text-gold-600">24 Jam</div>
              <div class="text-sm text-gray-500">Layanan Order</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="py-16 md:py-20 bg-gradient-to-r from-gold-600 to-gold-500">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-serif font-bold text-white mb-4">
        Butuh Rangkaian Bunga?
      </h2>
      <p class="text-gold-100 text-lg mb-8 max-w-2xl mx-auto">
        Hubungi kami sekarang untuk konsultasi dan pemesanan. Kami siap membantu mewujudkan rangkaian bunga impian Anda.
      </p>
      <a
        href={getWhatsAppUrl()}
        target="_blank"
        rel="noopener"
        class="inline-flex items-center px-8 py-4 bg-white text-gold-600 font-bold rounded-lg hover:bg-gold-50 transition-colors shadow-lg"
      >
        <svg class="w-6 h-6 mr-2" fill="currentColor" viewBox="0 0 24 24">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z" />
          <path d="M12 0C5.373 0 0 5.373 0 12c0 2.625.846 5.059 2.284 7.034L.789 23.492a.5.5 0 00.611.611l4.458-1.495A11.96 11.96 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-2.379 0-4.574-.826-6.305-2.207l-.44-.351-3.237 1.085 1.085-3.237-.351-.44A9.96 9.96 0 012 12C2 6.486 6.486 2 12 2s10 4.486 10 10-4.486 10-10 10z" />
        </svg>
        Pesan via WhatsApp
      </a>
    </div>
  </section>
</BaseLayout>
