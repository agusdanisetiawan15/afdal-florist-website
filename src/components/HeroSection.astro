---
import { getWhatsAppUrl } from "../data/products";
---

<section class="relative overflow-hidden bg-gradient-to-br from-white via-gold-50 to-gold-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-32">
    <div class="flex flex-col items-center text-center">
      <!-- Logo -->
      <img
        src="/images/LOGO-AFDAL FLORIST.png"
        alt="Afdal Florist Logo"
        class="w-44 md:w-60 h-auto mb-8"
      />

      <!-- Heading -->
      <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-serif font-bold text-gray-900 leading-tight max-w-4xl">
        Rangkaian Bunga Terbaik untuk
        <span class="text-gold-600">Momen Istimewa</span> Anda
      </h1>

      <!-- Subheading -->
      <p class="mt-6 text-lg md:text-xl text-gray-600 max-w-2xl">
        Toko bunga terpercaya di Rangkasbitung. Kami menyediakan buket bunga segar,
        papan bunga, dan rangkaian kustom untuk setiap kesempatan.
      </p>

      <!-- CTA Buttons -->
      <div class="mt-10 flex flex-col sm:flex-row gap-4">
        <a
          href="/katalog"
          class="inline-flex items-center justify-center px-8 py-3.5 bg-gold-600 text-white font-semibold rounded-lg hover:bg-gold-700 transition-colors shadow-lg shadow-gold-600/25"
        >
          Lihat Katalog
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a
          href={getWhatsAppUrl()}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center justify-center px-8 py-3.5 border-2 border-gold-600 text-gold-600 font-semibold rounded-lg hover:bg-gold-600 hover:text-white transition-colors"
        >
          <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z" />
            <path d="M12 0C5.373 0 0 5.373 0 12c0 2.625.846 5.059 2.284 7.034L.789 23.492a.5.5 0 00.611.611l4.458-1.495A11.96 11.96 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-2.379 0-4.574-.826-6.305-2.207l-.44-.351-3.237 1.085 1.085-3.237-.351-.44A9.96 9.96 0 012 12C2 6.486 6.486 2 12 2s10 4.486 10 10-4.486 10-10 10z" />
          </svg>
          Hubungi Kami
        </a>
      </div>
    </div>
  </div>

  <!-- Decorative Elements -->
  <div class="absolute top-0 left-0 w-72 h-72 bg-gold-200 rounded-full -translate-x-1/2 -translate-y-1/2 opacity-20 blur-3xl"></div>
  <div class="absolute bottom-0 right-0 w-96 h-96 bg-gold-300 rounded-full translate-x-1/3 translate-y-1/3 opacity-15 blur-3xl"></div>
</section>
