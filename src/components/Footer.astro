---
import { STORE_INFO, getWhatsAppUrl } from "../data/products";
---

<footer class="bg-gray-900 text-gray-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
      <!-- Brand -->
      <div>
        <div class="flex items-center gap-3 mb-4">
          <img src="/images/LOGO-AFDAL FLORIST.png" alt="Afdal Florist" class="h-10 w-auto" />
          <span class="text-xl font-serif font-bold text-gold-400">Afdal Florist</span>
        </div>
        <p class="text-sm leading-relaxed text-gray-400">
          Toko bunga terpercaya di Rangkasbitung. Menyediakan berbagai rangkaian bunga segar untuk
          momen spesial Anda.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-gold-400 font-semibold mb-4">Navigasi</h3>
        <ul class="space-y-2">
          <li><a href="/" class="text-sm hover:text-gold-400 transition-colors">Home</a></li>
          <li><a href="/katalog" class="text-sm hover:text-gold-400 transition-colors">Katalog</a></li>
          <li><a href="/#tentang-kami" class="text-sm hover:text-gold-400 transition-colors">Tentang Kami</a></li>
          <li><a href="/kontak" class="text-sm hover:text-gold-400 transition-colors">Kontak</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-gold-400 font-semibold mb-4">Hubungi Kami</h3>
        <ul class="space-y-3">
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-gold-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span class="text-sm">{STORE_INFO.address}</span>
          </li>
          <li>
            <a href={getWhatsAppUrl()} target="_blank" rel="noopener" class="flex items-center gap-3 hover:text-gold-400 transition-colors">
              <svg class="w-5 h-5 text-gold-500 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z" />
                <path d="M12 0C5.373 0 0 5.373 0 12c0 2.625.846 5.059 2.284 7.034L.789 23.492a.5.5 0 00.611.611l4.458-1.495A11.96 11.96 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-2.379 0-4.574-.826-6.305-2.207l-.44-.351-3.237 1.085 1.085-3.237-.351-.44A9.96 9.96 0 012 12C2 6.486 6.486 2 12 2s10 4.486 10 10-4.486 10-10 10z" />
              </svg>
              <span class="text-sm">WhatsApp</span>
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="border-t border-gray-800 mt-10 pt-6 text-center">
      <p class="text-sm text-gray-500">
        &copy; 2026 Afdal Florist. Semua hak dilindungi.
      </p>
    </div>
  </div>
</footer>
