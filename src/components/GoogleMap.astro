---
interface Props {
  embedUrl: string;
}

const { embedUrl } = Astro.props;
---

<div class="w-full rounded-2xl overflow-hidden shadow-lg border border-gray-200">
  <iframe
    src={embedUrl}
    width="100%"
    height="400"
    style="border:0;"
    allowfullscreen=""
    loading="lazy"
    referrerpolicy="no-referrer-when-downgrade"
    title="Lokasi Afdal Florist"
    class="w-full"
  ></iframe>
</div>
